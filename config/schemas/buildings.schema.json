{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "buildings.schema.json",
  "type": "object",
  "required": ["buildings"],
  "properties": {
    "buildings": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "cost", "prosperityBase", "unlockStep", "explanation"],
        "properties": {
          "id":           { "type": "string", "pattern": "^B[0-9]{2}$" },
          "name":         { "type": "string" },
          "category":     { "type": "string", "enum": ["core","production","housing","magic","refinement","trade","defense","beauty"] },
          "cost":         { "type": "object" },
          "maxCount":     { "type": ["integer","null"] },
          "baseOutput":   { "type": "object" },
          "prosperityBase": { "type": "object" },
          "terrainBonus": { "type": ["object","null"] },
          "neighborBonus": { "type": ["object","null"] },
          "neighborConflict": { "type": ["array","null"] },
          "unlockStep":   { "type": "string" },
          "explanation":  { "type": "string" }
        }
      }
    }
  }
}
